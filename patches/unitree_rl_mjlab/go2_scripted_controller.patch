+
+private:
+    static bool env_enabled(const char* name, bool default_value = false)
+    {
+        const char* value = std::getenv(name);
+        if(!value) return default_value;
+        std::string text(value);
+        return !(text.empty() || text == "0" || text == "false" || text == "False" || text == "FALSE");
+    }
+
+    static double env_double(const char* name, double default_value)
+    {
+        const char* value = std::getenv(name);
+        if(!value) return default_value;
+        try
+        {
+            return std::stod(value);
+        }
+        catch(...)
+        {
+            return default_value;
+        }
+    }
+
+    static bool in_window(double elapsed, double start, double duration, double repeat_period)
+    {
+        if(repeat_period > 0.0 && elapsed >= repeat_period)
+        {
+            elapsed = std::fmod(elapsed, repeat_period);
+        }
+        return elapsed >= start && elapsed < (start + duration);
+    }
+
+    static void apply_scripted_joystick()
+    {
+        if(!env_enabled("UNITREE_MJLAB_AUTOSTART")) return;
+        if(!lowstate) return;
+
+        static const auto start_time = std::chrono::steady_clock::now();
+        const double elapsed = std::chrono::duration<double>(std::chrono::steady_clock::now() - start_time).count();
+
+        const double button_duration = env_double("UNITREE_MJLAB_BUTTON_DURATION", 1.0);
+        const double repeat_period = env_double("UNITREE_MJLAB_REPEAT_PERIOD", 0.0);
+        const double fixstand_time = env_double("UNITREE_MJLAB_FIXSTAND_TIME", 0.1);
+        const double velocity_time = env_double("UNITREE_MJLAB_VELOCITY_TIME", 4.0);
+
+        auto& joy = lowstate->joystick;
+        const bool press_fixstand = in_window(elapsed, fixstand_time, button_duration, repeat_period);
+        const bool press_velocity = in_window(elapsed, velocity_time, button_duration, repeat_period);
+
+        joy.LT(press_fixstand ? 1.0f : 0.0f);
+        joy.up(press_fixstand ? 1 : 0);
+        joy.RT(press_velocity ? 1.0f : 0.0f);
+        joy.A(press_velocity ? 1 : 0);
+
+        double vx = env_double("UNITREE_MJLAB_VX", 0.3);
+        double vy = env_double("UNITREE_MJLAB_VY", 0.0);
+        double yaw = env_double("UNITREE_MJLAB_YAW", 0.0);
+
+        if(env_enabled("UNITREE_MJLAB_TELEOP"))
+        {
+            const double linear = env_double("UNITREE_MJLAB_TELEOP_LINEAR", 0.8);
+            const double lateral = env_double("UNITREE_MJLAB_TELEOP_LATERAL", 0.6);
+            const double yaw_rate = env_double("UNITREE_MJLAB_TELEOP_YAW", 0.8);
+            vx = 0.0;
+            vy = 0.0;
+            yaw = 0.0;
+
+            if(keyboard)
+            {
+                const std::string key = keyboard->key();
+                if(key == "w" || key == "up") vx = linear;
+                else if(key == "s" || key == "down") vx = -linear;
+                else if(key == "a" || key == "left") vy = lateral;
+                else if(key == "d" || key == "right") vy = -lateral;
+                else if(key == "q") yaw = yaw_rate;
+                else if(key == "e") yaw = -yaw_rate;
+            }
+        }
+
+        joy.ly(static_cast<float>(std::clamp(vx, -1.0, 1.0)));
+        joy.lx(static_cast<float>(std::clamp(-vy, -1.0, 1.0)));
+        joy.rx(static_cast<float>(std::clamp(-yaw, -1.0, 1.0)));
+    }
+};
