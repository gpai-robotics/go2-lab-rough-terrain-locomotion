-            "body_names": [
-                "left_ankle_roll_link",
-                "right_ankle_roll_link",
-                "left_wrist_yaw_link",
-                "right_wrist_yaw_link",
-            ],
-        },
-    )
-
-
-##
-# Environment configuration
-##
-
-
-@configclass
-class RobotEnvCfg(ManagerBasedRLEnvCfg):
